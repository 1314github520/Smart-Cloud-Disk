<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 外圈黑色唱片主体 -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#111111" />
            <stroke android:width="1dp" android:color="#333333" />
        </shape>
    </item>

    <!-- 唱片纹理效果 -->
    <item android:top="20dp" android:bottom="20dp" android:left="20dp" android:right="20dp">
        <shape android:shape="oval">
            <stroke android:width="1dp" android:color="#22FFFFFF" />
        </shape>
    </item>

    <!-- 中心 App 图标背景 -->
    <item android:top="70dp" android:bottom="70dp" android:left="70dp" android:right="70dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>

    <!-- 中心 App 图标 -->
    <item android:top="75dp" android:bottom="75dp" android:left="75dp" android:right="75dp">
        <bitmap android:src="@mipmap/my_ic_foreground" android:gravity="center" />
    </item>
</layer-list>
