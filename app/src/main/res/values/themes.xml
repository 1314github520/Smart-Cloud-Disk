<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <!-- 基础主题 -->
    <style name="Base.Theme.CloudDisk" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">#2196F3</item>
        <item name="android:statusBarColor">#2196F3</item>
    </style>

    <style name="Theme.CloudDisk" parent="Base.Theme.CloudDisk" />

    <!-- 启动页主题：优化美化版 -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- 1. 设置背景颜色 (可以改为你的品牌色，比如 #2196F3) -->
        <item name="windowSplashScreenBackground">#2196F3</item>

        <!-- 2. 设置中心 Logo (建议使用你刚生成的 my_ic_foreground) -->
        <item name="windowSplashScreenAnimatedIcon">@mipmap/my_ic_foreground</item>

        <!-- 3. 设置 Logo 在启动后的退场动画持续时间 (可选) -->
        <item name="windowSplashScreenAnimationDuration">200</item>

        <item name="postSplashScreenTheme">@style/Theme.CloudDisk</item>
    </style>
</resources>